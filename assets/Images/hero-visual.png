<svg width="1600" height="1200" viewBox="0 0 1600 1200" xmlns="http://www.w3.org/2000/svg" role="img">
  <title>Flujo Documental Inteligente – DocuStream</title>
  <desc>Ilustración estilo startup de documentos conectados por líneas curvas mint con nodos semánticos e iconos de IA</desc>

  <!-- Fondo blanco -->
  <rect width="1600" height="1200" fill="#f8f8f8"/>

  <!-- Grid de puntos decorativos -->
  <g opacity=".08">
    <circle cx="100" cy="100" r="4" fill="#4EF0C3"/>
    <circle cx="300" cy="100" r="4" fill="#4EF0C3"/>
    <circle cx="500" cy="100" r="4" fill="#4EF0C3"/>
    <circle cx="700" cy="100" r="4" fill="#4EF0C3"/>
    <circle cx="900" cy="100" r="4" fill="#4EF0C3"/>
    <circle cx="1100" cy="100" r="4" fill="#4EF0C3"/>
    <circle cx="1300" cy="100" r="4" fill="#4EF0C3"/>
    <circle cx="1500" cy="100" r="4" fill="#4EF0C3"/>
    <circle cx="100" cy="300" r="4" fill="#4EF0C3"/>
    <circle cx="1500" cy="300" r="4" fill="#4EF0C3"/>
    <circle cx="100" cy="600" r="4" fill="#4EF0C3"/>
    <circle cx="1500" cy="600" r="4" fill="#4EF0C3"/>
    <circle cx="100" cy="900" r="4" fill="#4EF0C3"/>
    <circle cx="300" cy="900" r="4" fill="#4EF0C3"/>
    <circle cx="1300" cy="900" r="4" fill="#4EF0C3"/>
    <circle cx="1500" cy="900" r="4" fill="#4EF0C3"/>
    <circle cx="100" cy="1100" r="4" fill="#4EF0C3"/>
    <circle cx="300" cy="1100" r="4" fill="#4EF0C3"/>
    <circle cx="700" cy="1100" r="4" fill="#4EF0C3"/>
    <circle cx="900" cy="1100" r="4" fill="#4EF0C3"/>
    <circle cx="1100" cy="1100" r="4" fill="#4EF0C3"/>
    <circle cx="1300" cy="1100" r="4" fill="#4EF0C3"/>
    <circle cx="1500" cy="1100" r="4" fill="#4EF0C3"/>
  </g>

  <!-- Líneas de flujo animadas (mint, dashed) -->
  <style>
    @keyframes dash { to { stroke-dashoffset: -80; } }
    @keyframes float1 { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-16px)} }
    @keyframes float2 { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-12px)} }
    @keyframes float3 { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-20px)} }
    @keyframes pulse  { 0%,100%{opacity:.65} 50%{opacity:1} }
    .flow { stroke-dasharray: 18 12; animation: dash 2s linear infinite; }
    .flow2 { stroke-dasharray: 18 12; animation: dash 2.8s linear infinite; }
    .d1 { animation: float1 3.8s ease-in-out infinite; }
    .d2 { animation: float2 4.4s ease-in-out infinite 0.6s; }
    .d3 { animation: float3 3.2s ease-in-out infinite 1.2s; }
    .d4 { animation: float2 5s   ease-in-out infinite 0.3s; }
    .d5 { animation: float1 4.1s ease-in-out infinite 1.8s; }
    .pulse { animation: pulse 2.4s ease-in-out infinite; }
    @media (prefers-reduced-motion: reduce) {
      .flow,.flow2,.d1,.d2,.d3,.d4,.d5,.pulse { animation: none; }
    }
  </style>

  <!-- Doc1 → Nodo central -->
  <path class="flow" fill="none" stroke="#4EF0C3" stroke-width="4" opacity=".75"
    d="M 440 360 Q 620 440 740 570"/>
  <!-- Doc2 → Nodo central -->
  <path class="flow" fill="none" stroke="#4EF0C3" stroke-width="4" opacity=".75"
    d="M 1160 360 Q 990 440 870 570"/>
  <!-- Nodo central → Doc3 -->
  <path class="flow" fill="none" stroke="#4EF0C3" stroke-width="4" opacity=".75"
    d="M 780 670 Q 660 780 440 840"/>
  <!-- Nodo central → Doc4 -->
  <path class="flow" fill="none" stroke="#4EF0C3" stroke-width="4" opacity=".75"
    d="M 830 670 Q 970 780 1160 840"/>
  <!-- Doc3 → Nodo Insights -->
  <path class="flow2" fill="none" stroke="#2bbd96" stroke-width="3" opacity=".55"
    d="M 440 950 Q 580 1020 740 1020"/>
  <!-- Doc4 → Nodo Insights -->
  <path class="flow2" fill="none" stroke="#2bbd96" stroke-width="3" opacity=".55"
    d="M 1160 950 Q 1020 1020 870 1020"/>

  <!-- Nodos pequeños en los caminos -->
  <circle class="pulse" cx="600" cy="460" r="10" fill="#4EF0C3" opacity=".9"/>
  <circle class="pulse" cx="1010" cy="460" r="10" fill="#4EF0C3" opacity=".9" style="animation-delay:.5s"/>
  <circle class="pulse" cx="550" cy="790" r="10" fill="#4EF0C3" opacity=".9" style="animation-delay:1s"/>
  <circle class="pulse" cx="1050" cy="790" r="10" fill="#4EF0C3" opacity=".9" style="animation-delay:1.5s"/>

  <!-- ======== NODO CENTRAL (motor semántico) ======== -->
  <g class="d2">
    <circle cx="800" cy="620" r="110" fill="#0d0d0d"/>
    <circle cx="800" cy="620" r="95" fill="none" stroke="#4EF0C3" stroke-width="2" stroke-dasharray="8 10" opacity=".5"/>
    <circle cx="800" cy="620" r="80" fill="none" stroke="#4EF0C3" stroke-width="1.5" opacity=".3"/>
    <!-- Ícono cerebro simplificado -->
    <path d="M768 608 Q768 580 780 578 Q788 578 790 586 Q794 578 804 578 Q816 578 820 594 Q830 594 832 608 Q832 622 822 626 Q822 636 814 642 Q806 650 800 648 Q794 650 786 642 Q778 636 778 626 Q768 622 768 608Z"
      fill="none" stroke="#4EF0C3" stroke-width="3.5" stroke-linejoin="round"/>
    <line x1="800" y1="582" x2="800" y2="648" stroke="#4EF0C3" stroke-width="2.5" opacity=".6"/>
    <line x1="776" y1="614" x2="824" y2="614" stroke="#4EF0C3" stroke-width="1.5" opacity=".4"/>
    <text font-family="system-ui,-apple-system,sans-serif" font-size="24" font-weight="600" fill="#4EF0C3" text-anchor="middle" x="800" y="686">Motor semántico</text>
  </g>

  <!-- ======== NODO INSIGHTS (abajo centro) ======== -->
  <g class="d2" style="animation-delay:.8s">
    <circle cx="800" cy="1020" r="44" fill="#0d0d0d" stroke="#4EF0C3" stroke-width="3"/>
    <!-- Estrella / destello -->
    <polygon points="800,996 806,1012 822,1012 810,1022 814,1038 800,1028 786,1038 790,1022 778,1012 794,1012"
      fill="#4EF0C3" opacity=".9"/>
    <text font-family="system-ui,-apple-system,sans-serif" font-size="22" font-weight="600" fill="#4EF0C3" text-anchor="middle" x="800" y="1082">Insights accionables</text>
  </g>

  <!-- ======== DOCUMENTO 1 – arriba izquierda ======== -->
  <g class="d1">
    <rect x="280" y="170" width="240" height="300" rx="18" fill="#ffffff" stroke="#e0e0e0" stroke-width="2"/>
    <rect x="280" y="170" width="240" height="300" rx="18" fill="none" stroke="#4EF0C3" stroke-width="2.5" opacity=".5"/>
    <!-- Líneas de texto -->
    <line x1="318" y1="240" x2="482" y2="240" stroke="#e5e5e5" stroke-width="5" stroke-linecap="round"/>
    <line x1="318" y1="266" x2="482" y2="266" stroke="#e5e5e5" stroke-width="5" stroke-linecap="round"/>
    <line x1="318" y1="292" x2="440" y2="292" stroke="#e5e5e5" stroke-width="5" stroke-linecap="round"/>
    <line x1="318" y1="318" x2="482" y2="318" stroke="#e5e5e5" stroke-width="5" stroke-linecap="round"/>
    <line x1="318" y1="344" x2="390" y2="344" stroke="#e5e5e5" stroke-width="5" stroke-linecap="round"/>
    <line x1="318" y1="370" x2="460" y2="370" stroke="#e5e5e5" stroke-width="5" stroke-linecap="round"/>
    <!-- Ícono lupa -->
    <circle cx="466" cy="200" r="18" fill="none" stroke="#4EF0C3" stroke-width="3.5"/>
    <line x1="480" y1="214" x2="494" y2="228" stroke="#4EF0C3" stroke-width="3.5" stroke-linecap="round"/>
    <text font-family="system-ui,-apple-system,sans-serif" font-size="26" font-weight="600" fill="#0d0d0d" text-anchor="middle" x="400" y="510">Análisis de uso</text>
  </g>

  <!-- ======== DOCUMENTO 2 – arriba derecha ======== -->
  <g class="d3">
    <rect x="1080" y="170" width="240" height="300" rx="18" fill="#ffffff" stroke="#e0e0e0" stroke-width="2"/>
    <rect x="1080" y="170" width="240" height="300" rx="18" fill="none" stroke="#4EF0C3" stroke-width="2.5" opacity=".5"/>
    <line x1="1118" y1="240" x2="1282" y2="240" stroke="#e5e5e5" stroke-width="5" stroke-linecap="round"/>
    <line x1="1118" y1="266" x2="1282" y2="266" stroke="#e5e5e5" stroke-width="5" stroke-linecap="round"/>
    <line x1="1118" y1="292" x2="1240" y2="292" stroke="#e5e5e5" stroke-width="5" stroke-linecap="round"/>
    <line x1="1118" y1="318" x2="1282" y2="318" stroke="#e5e5e5" stroke-width="5" stroke-linecap="round"/>
    <line x1="1118" y1="344" x2="1200" y2="344" stroke="#e5e5e5" stroke-width="5" stroke-linecap="round"/>
    <line x1="1118" y1="370" x2="1260" y2="370" stroke="#e5e5e5" stroke-width="5" stroke-linecap="round"/>
    <!-- Ícono rayo -->
    <polygon points="1218,178 1198,214 1208,214 1188,252 1228,206 1212,206" fill="#4EF0C3"/>
    <text font-family="system-ui,-apple-system,sans-serif" font-size="26" font-weight="600" fill="#0d0d0d" text-anchor="middle" x="1200" y="510">Detección obsolescencia</text>
  </g>

  <!-- ======== DOCUMENTO 3 – abajo izquierda ======== -->
  <g class="d4">
    <rect x="280" y="740" width="240" height="300" rx="18" fill="#ffffff" stroke="#e0e0e0" stroke-width="2"/>
    <rect x="280" y="740" width="240" height="300" rx="18" fill="none" stroke="#4EF0C3" stroke-width="2.5" opacity=".5"/>
    <line x1="318" y1="810" x2="482" y2="810" stroke="#e5e5e5" stroke-width="5" stroke-linecap="round"/>
    <line x1="318" y1="836" x2="482" y2="836" stroke="#e5e5e5" stroke-width="5" stroke-linecap="round"/>
    <line x1="318" y1="862" x2="440" y2="862" stroke="#e5e5e5" stroke-width="5" stroke-linecap="round"/>
    <line x1="318" y1="888" x2="482" y2="888" stroke="#e5e5e5" stroke-width="5" stroke-linecap="round"/>
    <line x1="318" y1="914" x2="390" y2="914" stroke="#e5e5e5" stroke-width="5" stroke-linecap="round"/>
    <line x1="318" y1="940" x2="460" y2="940" stroke="#e5e5e5" stroke-width="5" stroke-linecap="round"/>
    <!-- Ícono engranaje -->
    <circle cx="316" cy="772" r="16" fill="none" stroke="#4EF0C3" stroke-width="3"/>
    <circle cx="316" cy="772" r="6" fill="#4EF0C3"/>
    <line x1="316" y1="752" x2="316" y2="758" stroke="#4EF0C3" stroke-width="3.5" stroke-linecap="round"/>
    <line x1="316" y1="786" x2="316" y2="792" stroke="#4EF0C3" stroke-width="3.5" stroke-linecap="round"/>
    <line x1="296" y1="772" x2="302" y2="772" stroke="#4EF0C3" stroke-width="3.5" stroke-linecap="round"/>
    <line x1="330" y1="772" x2="336" y2="772" stroke="#4EF0C3" stroke-width="3.5" stroke-linecap="round"/>
    <line x1="303" y1="759" x2="307" y2="763" stroke="#4EF0C3" stroke-width="3" stroke-linecap="round"/>
    <line x1="325" y1="781" x2="329" y2="785" stroke="#4EF0C3" stroke-width="3" stroke-linecap="round"/>
    <text font-family="system-ui,-apple-system,sans-serif" font-size="26" font-weight="600" fill="#0d0d0d" text-anchor="middle" x="400" y="1082">Automatización</text>
  </g>

  <!-- ======== DOCUMENTO 4 – abajo derecha ======== -->
  <g class="d5">
    <rect x="1080" y="740" width="240" height="300" rx="18" fill="#ffffff" stroke="#e0e0e0" stroke-width="2"/>
    <rect x="1080" y="740" width="240" height="300" rx="18" fill="none" stroke="#4EF0C3" stroke-width="2.5" opacity=".5"/>
    <line x1="1118" y1="810" x2="1282" y2="810" stroke="#e5e5e5" stroke-width="5" stroke-linecap="round"/>
    <line x1="1118" y1="836" x2="1282" y2="836" stroke="#e5e5e5" stroke-width="5" stroke-linecap="round"/>
    <line x1="1118" y1="862" x2="1240" y2="862" stroke="#e5e5e5" stroke-width="5" stroke-linecap="round"/>
    <line x1="1118" y1="888" x2="1282" y2="888" stroke="#e5e5e5" stroke-width="5" stroke-linecap="round"/>
    <line x1="1118" y1="914" x2="1200" y2="914" stroke="#e5e5e5" stroke-width="5" stroke-linecap="round"/>
    <line x1="1118" y1="940" x2="1260" y2="940" stroke="#e5e5e5" stroke-width="5" stroke-linecap="round"/>
    <!-- Ícono barras chart -->
    <rect x="1104" y="786" width="10" height="22" rx="3" fill="#4EF0C3"/>
    <rect x="1120" y="776" width="10" height="32" rx="3" fill="#4EF0C3"/>
    <rect x="1136" y="780" width="10" height="28" rx="3" fill="#4EF0C3"/>
    <line x1="1100" y1="808" x2="1152" y2="808" stroke="#4EF0C3" stroke-width="2.5" stroke-linecap="round"/>
    <text font-family="system-ui,-apple-system,sans-serif" font-size="26" font-weight="600" fill="#0d0d0d" text-anchor="middle" x="1200" y="1082">Predicción Big Data</text>
  </g>

  <!-- ======== TÍTULO ======== -->
  <text font-family="system-ui,-apple-system,sans-serif" font-size="64" font-weight="800" fill="#0d0d0d" text-anchor="middle" x="800" y="84" letter-spacing="-1">DocuStream</text>
  <text font-family="system-ui,-apple-system,sans-serif" font-size="28" font-weight="400" fill="#4EF0C3" text-anchor="middle" x="800" y="124" letter-spacing="2">Flujo Documental Inteligente</text>
</svg>
